<Window x:Class="GigNovaWPFApp.UserControls.BlockedListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blocked Items"
        Width="640" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="#1B1B1B">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#242424" BorderBrush="#E94560" BorderThickness="1" CornerRadius="10" Margin="6">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Blocked Items" Foreground="White" FontSize="22" FontWeight="Bold"/>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TypeComboBox" Grid.Column="0" Height="34" SelectionChanged="TypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Gigs" IsSelected="True"/>
                    <ComboBoxItem Content="Categories"/>
                </ComboBox>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Margin="10,0,0,0" Height="34" Background="#171717" Foreground="White" BorderBrush="#E94560" VerticalContentAlignment="Center" Padding="8,0,8,0"/>
                <Button Grid.Column="2" Content="Search" Style="{StaticResource DialogButtonStyle}" Width="90" Height="34" Background="#E94560" Margin="10,0,0,0" Click="Search_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ItemsPanel"/>
            </ScrollViewer>

            <StackPanel x:Name="PaginationPanel" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <Button Grid.Row="4" Content="Close" Style="{StaticResource DialogButtonStyle}" Width="100" Height="36" Background="#3A3A3A" HorizontalAlignment="Right" Margin="0,12,0,0" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>