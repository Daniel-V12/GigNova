<Window x:Class="GigNovaWPFApp.UserControls.CategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Category"
        Width="420" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1B1B1B">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#242424" BorderBrush="#E94560" BorderThickness="1" CornerRadius="10" Margin="6">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Add Category" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock Grid.Row="1" Text="Category Name" Foreground="#BFBFBF" FontSize="14" Margin="0,16,0,6"/>
            <TextBox x:Name="NameTextBox" Grid.Row="2" Background="#171717" Foreground="White" BorderBrush="#E94560" Height="34" VerticalContentAlignment="Center" Padding="8,0,8,0"/>
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource DialogButtonStyle}" Width="100" Height="36" Background="#3A3A3A" Click="Cancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="ActionButton" Content="Create" Style="{StaticResource DialogButtonStyle}" Width="100" Height="36" Background="#E94560" Click="Create_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>