@model GigNovaModels.ViewModels.CustomizeOrderViewModel

@{
    ViewData["Title"] = "CustomizeOrder";
    Layout = Context.Session.GetString("actor") == "seller"
        ? "~/Views/Shared/MasterSellerPage.cshtml"
        : "~/Views/Shared/MasterBuyerPage.cshtml";
}

<link href="~/css/buyer_pages/customizeorder_page.css" rel="stylesheet" />

<div class="customize-order-container">
    <h1 class="page-title">Customize Your Order</h1>

    @if (TempData["CustomizeOrderMessage"] != null)
    {
        <div class="order-message">@TempData["CustomizeOrderMessage"]</div>
    }

    @if (Model?.order == null)
    {
        <div class="order-box">Order details were not found.</div>
    }
    else
    {
        <div class="customize-grid">

            <form asp-controller="Buyer"
                  asp-action="CustomizeOrder"
                  method="post"
                  enctype="multipart/form-data"
                  class="order-box">

                <h2 class="section-title">Order Requirements</h2>

                <!-- DTO: CustomizeOrderModel.Gig_id -->
                <input type="hidden"
                       name="Gig_id"
                       value="@Model.order.Gig_id" />

                <!-- DTO: CustomizeOrderModel.requirements -->
                <div class="form-group">
                    <label class="form-label" for="requirements">Describe what you need</label>

                    <textarea id="requirements"
                              name="requirements"
                              class="form-textarea"
                              placeholder="Write your project requirements, details, goals, and anything the seller should know..."
                              maxlength="2000">@Model.order.Order_requirements</textarea>
                </div>

                <!-- DTO: CustomizeOrderModel.Files -->
                <div class="form-group">
                    <label class="form-label" for="Files">Upload files (optional)</label>

                    <input id="Files"
                           name="Files"
                           type="file"
                           class="form-file"
                           multiple />

                    <p class="help-text">You can upload multiple files of any type. This is optional.</p>
                    <p id="selectedFilesText" class="help-text"></p>
                </div>

                @if (Model.order_files != null && Model.order_files.Count > 0)
                {
                    <div class="form-group">
                        <p class="form-label">Uploaded files on this order</p>

                        <ul class="uploaded-files-list">
                            @foreach (var file in Model.order_files)
                            {
                                if (!string.IsNullOrEmpty(file?.Order_file_name))
                                {
                                    <li>@file.Order_file_name</li>
                                }
                            }
                        </ul>
                    </div>
                }

                <button type="submit" class="pay-btn">Pay & Create Order</button>
            </form>

            <aside class="summary-box">
                <h2 class="section-title">Order Summary</h2>

                <div class="summary-gig">
                    @if (!string.IsNullOrEmpty(Model.gig?.Gig_photo))
                    {
                        <img src="http://localhost:7059/Images/@Model.gig.Gig_photo"
                             alt="@Model.gig?.Gig_name"
                             class="summary-image" />
                    }

                    <div>
                        <p class="summary-gig-name">
                            @(Model.gig?.Gig_name ?? $"Gig #{Model.order.Gig_id}")
                        </p>

                        @if (!string.IsNullOrEmpty(Model.gig?.Gig_description))
                        {
                            <p class="summary-description">@Model.gig.Gig_description</p>
                        }
                    </div>
                </div>

                <div class="summary-row">
                    <span>Gig ID</span>
                    <strong>#@Model.order.Gig_id</strong>
                </div>

                <div class="summary-row">
                    <span>Seller</span>
                    <strong>
                        @(Model.seller?.Seller_display_name ?? $"Seller #{Model.order.Seller_id}")
                        (@(Model.seller_person?.Person_username ?? "unknown"))
                    </strong>
                </div>

                <div class="summary-row">
                    <span>Delivery Time</span>
                    <strong>
                        @(Model.delivery_time?.Delivery_time_name ?? $"Delivery ID {Model.gig?.Delivery_time_id}")
                    </strong>
                </div>

                <div class="summary-row">
                    <span>Status</span>
                    <strong>Pending</strong>
                </div>

                <div class="summary-row total">
                    <span>Total</span>
                    <strong>$@(Model.gig?.Gig_price ?? 0)</strong>
                </div>
            </aside>

        </div>
    }
</div>

<script>
        const fileInput = document.getElementById("Files");
    const selectedFilesText = document.getElementById("selectedFilesText");

    if (fileInput && selectedFilesText) {
        fileInput.addEventListener("change", function () {
        const files = Array.from(fileInput.files || []);

            if (files.length === 0) {
            selectedFilesText.innerText = "";
            return;
        }

        selectedFilesText.innerText =
            "Selected files (" + files.length + "): " + files.map(f => f.name).join(", ");
    });
    }
</script>